# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/authbox

# JWT
SECRET_KEY=your-secret-key-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
FRONTEND_URL=http://localhost:8080

# Email (for password reset — plug in your SMTP or set to "console" for dev)
MAIL_MODE=console
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
